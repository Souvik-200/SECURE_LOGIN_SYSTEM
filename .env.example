# Copy to .env and adjust. Never commit .env.

# Flask
FLASK_APP=wsgi.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string

# JWT (use different value from SECRET_KEY in production)
JWT_SECRET_KEY=change-this-jwt-secret

# Database: SQLite (default) or MySQL
# SQLite (relative paths use instance/ via app config)
DATABASE_URL=sqlite:///instance/app.db
# MySQL example:
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/secure_login

# HTTPS-only JWT cookie in production
JWT_COOKIE_SECURE=false

# Demo only: allow choosing Admin on registration form (disable in production)
ALLOW_PUBLIC_ADMIN_REGISTRATION=false

# Account lockout
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
